<aside class="app-sidebar">
  <div class="sidebar-top">
    <div class="sidebar-logo">
      <%= link_to root_path do %>
        <%= image_tag "logo.svg" %>
        <span class="sidebar-logo__name">VESTA</span>
      <% end %>
    </div>

    <%= link_to new_mission_path, class: "btn btn-danger vesta-btn w-100 mt-3 text-white rounded-pill" do %>
      <i class="fa-regular fa-square-plus pe-2 d-inline-block"></i> Nouvelle mission
    <% end %>

    <nav class="sidebar-nav mt-4">
      <p class="sidebar-nav__label">PILOTAGE</p>
      <%= link_to root_path, class: "sidebar-nav__link #{current_page?(root_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-table-columns"></i>
        Tableau de bord
      <% end %>
      <%= link_to missions_path, class: "sidebar-nav__link #{current_page?(missions_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-briefcase"></i>
        Missions
        <span class="sidebar-nav__count"><%= current_user.missions.count %></span>
      <% end %>
      <%= link_to clients_path, class: "sidebar-nav__link #{current_page?(clients_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-users"></i>
        Clients
        <span class="sidebar-nav__count"><%= current_user.clients.count %></span>
      <% end %>
      <%= link_to step_templates_path, class: "sidebar-nav__link #{current_page?(step_templates_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-layer-group"></i>
        Templates
        <span class="sidebar-nav__count"><%= current_user.step_templates.count %></span>
      <% end %>
      <%= link_to edit_profile_path, class: "sidebar-nav__link #{current_page?(edit_profile_path) ? 'active' : ''}" do %>
        <i class="fa-solid fa-user"></i>
        Profil
      <% end %>
    </nav>
  </div>

  <div class="sidebar-profile">
    <div class="sidebar-profile__user">
      <%= render "shared/user_avatar", user: current_user, css_class: "sidebar-profile__avatar" %>
      <div class="sidebar-profile__info">
        <p class="sidebar-profile__name"><%= user_display_name(current_user) %></p>
        <p class="sidebar-profile__role"><%= current_user.profile&.profession %></p>
      </div>
    </div>
    <div class="sidebar-profile__gmail">
      <% if current_user.gmail_connection.present? %>
        <%= button_to user_google_oauth2_omniauth_authorize_path,
            method: :post,
            data: { turbo: false },
            class: "sidebar-profile__gmail-button" do %>
          <i class="fa-brands fa-google"></i>
          Changer de compte Gmail
        <% end %>
        <p class="sidebar-profile__gmail-email">
          <%= current_user.gmail_connection.email %>
        </p>
      <% else %>
        <%= button_to user_google_oauth2_omniauth_authorize_path,
            method: :post,
            data: { turbo: false },
            class: "sidebar-profile__gmail-button" do %>
          <i class="fa-brands fa-google"></i>
          Connecter Gmail
        <% end %>
      <% end %>
    </div>

    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "sidebar-logout" do %>
      <i class="fa-solid fa-arrow-right-from-bracket"></i>
      Se déconnecter
    <% end %>
  </div>
</aside>
