<%= simple_form_for mission, class: "new-mission-form" do |f| %>
  <div class="row">
    <div class="col-12 col-md-6">
      <div class="bg-white border rounded-4 p-4">
        <div class="form-group mb-4">
          <%= f.input :title,
            label: "Nom de la mission",
            placeholder: "ex. Loft Bastille - Rénovation",
            input_html: { class: "rounded-4" } %>
        </div>
        <div class="form-group">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <label class="form-label mb-0">Client</label>
            <span class="new-mission--add-client-link">
              <%= link_to new_client_path, data: { turbo_frame: "modal" } do %>
                <i class="fa-regular fa-square-plus"></i> Ajouter un client
              <% end %>
            </span>
          </div>
          <%= f.association :client,
            collection: @clients,
            label_method: ->(c) { "#{c.first_name} #{c.last_name}" },
            label: false,
            prompt: "Sélectionnez un client" %>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="bg-white border rounded-4 overflow-hidden new-mission--steps">
        <div class="bg-light border-bottom p-4">
          <div class="d-flex justify-content-between align-items-center gap-2">
            <div>
              <strong class="new-mission--steps-title">Etapes du projet</strong>
              <span class="new-mission--steps-subtitle text-muted">Définir les étapes clés de votre projet.</span>
            </div>
            <div>
              <button type="button" class="btn btn-outline-dark btn-sm rounded-pill">
                Modèles <i class="fa-solid fa-wand-magic-sparkles"></i>
              </button>
            </div>
          </div>
        </div>
        <div class="p-4">
          <p>To do: template management. The button "modeles" is for selecting pre-defined templates for the mission steps.</p>
        </div>
      </div>
    </div>
  </div>
  <div class="row mt-4">
    <div class="col-12">
      <div class="bg-white border rounded-4 p-4">
        <div class="form-group">
          <%= f.input :description,
            as: :text,
            label: "Brief de la mission",
            placeholder: "Décrivez les objectifs, les contraintes et le périmètre de la mission...",
            input_html: { class: "rounded-4" } %>
        </div>
      </div>
    </div>
  </div>
  <div class="d-flex justify-content-between align-items-center mt-4">
    <%= link_to missions_path, class: "text-danger cancel-btn" do %>
      <i class="fa-solid fa-angle-left d-inline-block me-2"></i> Annuler
    <% end %>
    <%= f.button :button, type: :submit, class: "btn btn-danger vesta-btn rounded-pill text-white" do %>
      <i class="fa-regular fa-square-plus pe-2 d-inline-block"></i> Ajouter une mission
    <% end %>
  </div>
<% end %>
