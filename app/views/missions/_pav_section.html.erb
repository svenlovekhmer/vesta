<% profile = local_assigns.fetch(:profile) { current_user.profile } %>
<div id="pav_section_<%= mission.id %>">
  <div class="pav-card border mb-4">
    <div class="pav-card__header">
      <div>
        <div class="pav-card__title-group">
          <h2 class="pav-card__title"><i class="fa-regular fa-circle-pause text-danger"></i> Points à valider</h2>
        </div>
        <% if pending_logs.any? %>
          <p class="pav-card__subtitle mt-1 mb-0">
            <span class="pav-card__subtitle--vesta"><%= vesta_count %> côté <%= profile&.first_name %> <%= profile&.last_name %></span>
            &middot;
            <span class="pav-card__subtitle--client"><%= client_count %> côté client</span>
          </p>
        <% end %>
      </div>
      <%= link_to new_modal_decision_logs_path(mission_id: mission.id),
            class: "pav-card__add-btn",
            data: { turbo_frame: "modal" } do %>
        <i class="fa-solid fa-plus"></i> Ajouter
      <% end %>
    </div>
    <% if pending_logs.any? %>
      <span class="step-link-hint">
        Vous pouvez lier vos points à valider avec une des étapes de votre mission.<br>Soit en drag&drop avec l'icône <i class="fa-solid fa-maximize d-inline-block mx-1"></i> soit via l'icône <i class="fa-solid fa-ellipsis-vertical d-inline-block ms-1"></i>
      </span>
      <div class="log-list">
        <% pending_logs.reverse.each do |log| %>
          <%= render "decision_logs/pav_log_item", log: log, profile: profile %>
        <% end %>
      </div>
     <% else %>
      <p>Aucun point à valider pour l'instant</p>
    <% end %>
  </div>
</div>
