<div id="gmail_panel_<%= mission.id %>">
  <% if mission.client.gmail_synthesis.present? %>
    <% ai_pending = mission.decision_logs.where(source: "gmail_ai", status: "pending") %>
    <% ai_decided = mission.decision_logs.where(source: "gmail_ai", status: "decided") %>

    <div class="ai-synthesis-panel">
      <button class="ai-synthesis-panel__toggle"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#ai_synthesis_collapse_<%= mission.id %>"
              aria-expanded="false"
              aria-controls="ai_synthesis_collapse_<%= mission.id %>">
        <span class="ai-synthesis-panel__toggle-left">
          <i class="fa-solid fa-wand-magic-sparkles text-danger me-2"></i>
          <span class="fw-semibold small">Synthèse IA des échanges</span>
        </span>
        <i class="fa-solid fa-chevron-down ai-synthesis-panel__chevron"></i>
      </button>

      <div class="collapse" id="ai_synthesis_collapse_<%= mission.id %>">
        <div class="ai-synthesis-panel__body" id="gmail_synthesis_area_<%= mission.client.id %>">
          <p class="small mb-0" style="white-space: pre-line;"><%= mission.client.gmail_synthesis %></p>

          <% if ai_decided.any? || ai_pending.any? %>
            <div class="row g-3 mt-2">
              <% if ai_decided.any? %>
                <div class="col-md-6">
                  <p class="fw-semibold mb-2 small text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">✅ Points validés</p>
                  <ul class="list-unstyled mb-0">
                    <% ai_decided.each do |log| %>
                      <li class="small mb-1">• <%= log.title %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
              <% if ai_pending.any? %>
                <div class="col-md-6">
                  <p class="fw-semibold mb-2 small text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">⏳ Points en attente</p>
                  <ul class="list-unstyled mb-0">
                    <% ai_pending.each do |log| %>
                      <li class="small mb-1">• <%= log.title %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
