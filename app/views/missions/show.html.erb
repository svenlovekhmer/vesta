<div class="container-fluid show-mission p-1">
  <h1 class="show-mission--title"><%= @mission.title %></h1>
  <div class="show-mission--subtitle d-flex align-items-center gap-4 mb-4">
    <div><%= mission_status_badge(@mission.mission_status) %></div>
    <div>Client : <%= "#{@mission.client.first_name} #{@mission.client.last_name}" %></div>
    <div>Dernière activité il y a <%= time_ago_in_words(@mission.last_activity_at) %></div>
  </div>

  <div class="row">
    <div class="col-md-4">
      <%= render "step_timeline", mission: @mission %>
    </div>
    <div class="col-md-8">
      <% profile = current_user.profile %>
      <% if @pending_logs.any? %>
        <div class="pav-card border mb-4">
          <div class="pav-card__header">
            <div class="pav-card__title-group">
              <h2 class="pav-card__title">Points à valider</h2>
            </div>
            <p class="pav-card__subtitle">
              <span class="pav-card__subtitle--vesta"><%= @vesta_pending_count %> côté <%= profile&.first_name %> <%= profile&.last_name %></span>
              &middot;
              <span class="pav-card__subtitle--client"><%= @client_pending_count %> côté client</span>
            </p>
          </div>
          <div class="pav-list">
            <% @pending_logs.each do |log| %>
              <%= render "decision_logs/pav_log_item", log: log, profile: profile %>
            <% end %>
          </div>
        </div>
      <% end %>
      <div class="bg-white border rounded-4 p-4 mb-4">fdfdsf</div>
    </div>
  </div>
</div>
