<div class="container-fluid mission-show">

  <%# ── En-tête ──────────────────────────────────────────────────────────── %>
  <div class="mission-show__header">
    <div class="mission-show__header-left">
      <h1 class="mission-show--title"
          data-controller="inline-edit"
          data-inline-edit-model-value="mission"
          data-inline-edit-url-value="<%= mission_path(@mission) %>"
          data-inline-edit-param-value="title">
        <span data-inline-edit-target="text"
              data-action="click->inline-edit#edit"
              title="Cliquer pour modifier"><%= @mission.title %></span>
        <input type="text"
               class="form-control d-none mission-show--title-input"
               data-inline-edit-target="input"
               data-action="blur->inline-edit#save keydown->inline-edit#keydown" />
      </h1>
      <div class="mission-show--subtitle">
        <div id="mission_status_badge"><%= mission_status_badge(@mission.mission_status) %></div>
        <div>Client : <%= "#{@mission.client.first_name} #{@mission.client.last_name}" %></div>
        <div>Dernière activité il y a <%= time_ago_in_words(@mission.last_activity_at, locale: :fr) %></div>
      </div>
    </div>

    <div class="mission-show__header-actions">
      <%# Ligne de boutons %>
      <div class="mission-show__header-btns">
        <%= link_to mission_portal_path(@mission.portal_token),
              target: "_blank",
              rel: "noopener",
              class: "btn btn-outline-secondary vesta-btn rounded-pill" do %>
          <i class="fa-regular fa-eye me-1"></i> Aperçu client
        <% end %>

        <%= render "analyze_btn", mission: @mission, current_user: current_user %>
      </div>

      <%# Ligne d'aide + pastille ? %>
      <%= render "shared/analyze_helper", scope: :mission %>

      <%# Ligne stats Gmail %>
      <% if @mission.client.gmail_last_synced_at.present? %>
        <div class="mission-show__gmail-stats">
          <svg class="mission-show__gmail-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <strong><%= @mission.client.gmail_messages_count.to_i %> email<%= "s" if @mission.client.gmail_messages_count.to_i > 1 %></strong>
          <span class="text-muted">&middot; synchronisé il y a <%= time_ago_in_words(@mission.client.gmail_last_synced_at) %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%= turbo_stream_from "gmail_sync_#{@mission.id}" %>

  <%# ── Onglets ────────────────────────────────────────────────────────────── %>
  <div data-controller="mission-tabs">
    <nav class="mission-tabs__nav">
      <button class="mission-tabs__btn mission-tabs__btn--active"
              data-tab="progression"
              data-mission-tabs-target="tab"
              data-action="click->mission-tabs#show">
        <i class="fa-solid fa-list-check me-2"></i>Progression
      </button>
      <button class="mission-tabs__btn"
              data-tab="documents"
              data-mission-tabs-target="tab"
              data-action="click->mission-tabs#show">
        <i class="fa-regular fa-folder-open me-2"></i>Documents
        <% if @documents.any? %>
          <span class="mission-tabs__count"><%= @documents.count %></span>
        <% end %>
      </button>
    </nav>

    <%# Tab: Progression %>
    <div data-mission-tabs-target="panel" data-panel="progression">

      <%# Zone de travail 2 colonnes %>
      <div class="mission-show__work-area" data-controller="step-link" data-step-link-mission-id-value="<%= @mission.id %>">
        <div class="mission-show__col-left">
          <%= render "step_timeline", mission: @mission %>
        </div>
        <div class="mission-show__col-right">
          <%= render "pav_section", mission: @mission, pending_logs: @pending_logs, vesta_count: @vesta_pending_count, client_count: @client_pending_count %>
        </div>
      </div>

      <%# Décisions actées — pleine largeur %>
      <%= render "decided_section", mission: @mission, decided_logs: @decided_logs %>

      <%# Synthèse IA — repliable, replié par défaut %>
      <%= render "gmail_panel", mission: @mission, current_user: current_user %>

    </div>

    <%# Tab: Documents %>
    <div data-mission-tabs-target="panel" data-panel="documents" class="d-none">
      <%= render "missions/documents_tab", mission: @mission, documents: @documents %>
    </div>
  </div>
</div>
