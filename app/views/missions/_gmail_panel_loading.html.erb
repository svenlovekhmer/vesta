<div id="gmail_panel_<%= mission.id %>">
  <div class="ai-synthesis-panel">
    <div class="ai-synthesis-panel__toggle ai-synthesis-panel__toggle--loading">
      <span class="ai-synthesis-panel__toggle-left">
        <div class="spinner-grow spinner-grow-sm text-danger me-2" role="status" aria-hidden="true"></div>
        <span class="fw-semibold small">Synthèse IA — Analyse en cours...</span>
      </span>
    </div>

    <div class="collapse show" id="ai_synthesis_collapse_<%= mission.id %>">
      <div class="ai-synthesis-panel__body" id="gmail_synthesis_area_<%= mission.client.id %>">
        <p class="small mb-0">
          <span id="gmail_synthesis_stream_<%= mission.client.id %>"></span><span class="gmail-cursor">▋</span>
        </p>
      </div>
    </div>
  </div>
</div>
