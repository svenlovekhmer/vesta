<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Vesta" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Vesta">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= favicon_link_tag asset_path('favicon-96x96.png'), sizes: "96x96" %>
    <%= favicon_link_tag asset_path('favicon.svg'), type: "image/svg+xml" %>
    <%= favicon_link_tag asset_path('favicon.ico') %>
    <%= favicon_link_tag asset_path('apple-touch-icon.png'), sizes: "180x180" %>
    <%= favicon_link_tag asset_path('site.webmanifest'), rel: "manifest", type: "application/manifest+json" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <% if user_signed_in? %>
      <div class="app-layout">
        <%= render "shared/sidebar" %>
        <main class="app-main">
          <%= render "shared/flashes" %>
          <%= render "shared/breadcrumb" %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <%= render "shared/flashes" %>
      <%= yield %>
    <% end %>
    <div class="modal fade" id="appModal" tabindex="-1" aria-hidden="true"
         data-controller="modal" data-bs-backdrop="static" data-bs-keyboard="false">
      <div class="modal-dialog">
        <div class="modal-content">
          <turbo-frame id="modal" data-modal-target="frame"></turbo-frame>
        </div>
      </div>
    </div>
  </body>
</html>
