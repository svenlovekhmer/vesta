<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo mb-4">
      <span class="sidebar-logo__icon">&#9632;</span>
      <span class="fw-bold" style="letter-spacing: 0.05em;">VESTA</span>
    </div>

    <h1 class="auth-title">Créer un compte</h1>
    <p class="text-muted mb-4">Rejoignez Vesta pour gérer vos missions et vos clients.</p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification class: "alert alert-danger rounded-4 py-2 px-3 mb-3" %>

      <div class="mb-3">
        <%= f.input :email,
          label: "Adresse email",
          required: true,
          autofocus: true,
          input_html: { autocomplete: "email", class: "rounded-4" } %>
      </div>

      <div class="mb-3">
        <%= f.input :password,
          label: "Mot de passe",
          required: true,
          hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
          input_html: { autocomplete: "new-password", class: "rounded-4" } %>
      </div>

      <div class="mb-4">
        <%= f.input :password_confirmation,
          label: "Confirmer le mot de passe",
          required: true,
          input_html: { autocomplete: "new-password", class: "rounded-4" } %>
      </div>

      <%= f.submit "Créer mon compte", class: "btn btn-danger rounded-pill w-100" %>
    <% end %>

    <div class="auth-links mt-3 text-center">
      <%= link_to "Déjà un compte ? Se connecter", new_session_path(resource_name) %>
    </div>
  </div>
</div>
