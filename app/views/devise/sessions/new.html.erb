<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo mb-4">
      <span class="sidebar-logo__icon">&#9632;</span>
      <span class="fw-bold" style="letter-spacing: 0.05em;">VESTA</span>
    </div>

    <h1 class="auth-title">Connexion</h1>
    <p class="text-muted mb-4">Bienvenue ! Connectez-vous pour accéder à votre espace.</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.error_notification class: "alert alert-danger rounded-4 py-2 px-3 mb-3" %>

      <div class="mb-3">
        <%= f.input :email,
          label: "Adresse email",
          required: false,
          autofocus: true,
          input_html: { autocomplete: "email", class: "rounded-4" } %>
      </div>

      <div class="mb-4">
        <%= f.input :password,
          label: "Mot de passe",
          required: false,
          input_html: { autocomplete: "current-password", class: "rounded-4" } %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-3">
          <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" %>
        </div>
      <% end %>

      <%= f.submit "Se connecter", class: "btn btn-danger vesta-btn text-white rounded-pill w-100" %>
    <% end %>

    <div class="auth-links mt-3 text-center">
      <%= link_to "Pas encore de compte ? S'inscrire", new_registration_path(resource_name) %>
    </div>
  </div>
</div>
