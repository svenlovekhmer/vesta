<div id="<%= dom_id(log) %>" class="log-item"
     draggable="true"
     data-action="dragstart->step-link#dragstart dragend->step-link#dragend"
     data-decision-log-id="<%= log.id %>">
  <span class="log-item__drag-handle" title="Glisser vers une étape">
    <i class="fa-solid fa-maximize"></i>
  </span>
  <span class="log-item__date"><%= format_date_fr(log.created_at) if log.created_at %></span>
  <div class="log-item__tag-col">
    <span class="log-item__tag log-item__tag--<%= log.owner_type %>">
      <%= log.owner_type == "provider" ? "#{profile&.first_name} #{profile&.last_name}" : "client" %>
    </span>
  </div>
  <div class="log-item__content">
    <div data-controller="inline-edit"
         data-inline-edit-model-value="decision_log"
         data-inline-edit-url-value="<%= decision_log_path(log) %>"
         data-inline-edit-param-value="title">
      <span class="log-item__title log-item__editable"
            data-inline-edit-target="text"
            data-action="click->inline-edit#edit"
            title="Cliquer pour modifier"><%= log.title.presence %></span>
      <input type="text"
             class="form-control form-control-sm d-none log-item__edit-input"
             data-inline-edit-target="input"
             data-action="blur->inline-edit#save keydown->inline-edit#keydown" />
    </div>
    <div data-controller="inline-edit"
         data-inline-edit-model-value="decision_log"
         data-inline-edit-url-value="<%= decision_log_path(log) %>"
         data-inline-edit-param-value="description">
      <span class="log-item__description log-item__editable"
            data-inline-edit-target="text"
            data-action="click->inline-edit#edit"
            title="Cliquer pour modifier"><%= log.description %></span>
      <textarea class="form-control form-control-sm d-none log-item__edit-input"
                rows="2"
                data-inline-edit-target="input"
                data-action="blur->inline-edit#save keydown->inline-edit#keydown"></textarea>
    </div>
    <div id="decision_log_pill_<%= log.id %>" class="log-item__linked-pill">
      <% if (blocker = log.mission_step_blockers.find { |b| b.blocking_status == "blocking" }) %>
        <%= render "mission_step_blockers/linked_pill", blocker: blocker %>
      <% end %>
    </div>
  </div>
  <div class="log-item__actions">
    <%= link_to resolve_modal_decision_log_path(log),
          class: "log-item__action-btn log-item__action-btn--resolve",
          title: "Marquer comme décidé",
          data: { turbo_frame: "modal" } do %>
      <i class="fa-solid fa-circle-check d-inline-block pe-1"></i> Résolu
    <% end %>
    <%= button_to decision_log_path(log),
          method: :delete,
          class: "log-item__action-btn log-item__action-btn--delete",
          title: "Supprimer",
          form: { class: "d-inline", data: { turbo_confirm: "Supprimer ce point à valider ?" } } do %>
      <i class="fa-solid fa-trash-can"></i>
    <% end %>
  </div>
</div>
