<div id="<%= dom_id(log) %>" class="log-item"
     data-decision-log-id="<%= log.id %>"
     data-controller="row-link"
     data-row-link-href-value="<%= mission_path(log.mission_id) %>"
     data-action="click->row-link#navigate"
     style="cursor: pointer;">
  <span class="log-item__date"><%= format_date_fr(log.created_at) if log.created_at %></span>
  <div class="log-item__tag-col">
    <span class="log-item__tag log-item__tag--<%= log.owner_type %>">
      <%= log.owner_type == "provider" ? "#{profile&.first_name} #{profile&.last_name}" : "client" %>
    </span>
  </div>
  <div class="log-item__content">
    <span class="log-item__title"><%= log.title.presence %></span>
    <span class="log-item__description"><%= log.description %></span>
    <div id="decision_log_pill_<%= log.id %>" class="log-item__linked-pill">
      <% if (blocker = log.mission_step_blockers.find { |b| b.blocking_status == "blocking" }) %>
        <%= render "mission_step_blockers/linked_pill", blocker: blocker %>
      <% end %>
    </div>
  </div>
</div>
