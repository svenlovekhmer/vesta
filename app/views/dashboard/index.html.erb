<div class="dashboard-header">
  <div>
    <h1 class="dashboard-header__title">Tableau de bord</h1>
    <p class="dashboard-header__subtitle">
      <% profile = current_user.profiles.first %>
      Bonjour <%= profile&.first_name || current_user.email.split("@").first %> &mdash;
      <%= @missions.count %> mission<%= @missions.count > 1 ? "s" : "" %> en cours
    </p>
  </div>
</div>

<%# Stats row %>
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="stat-card">
      <p class="stat-card__number"><%= @stats[:active] %></p>
      <p class="stat-card__label">missions <strong>actives</strong></p>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card stat-card--highlight">
      <p class="stat-card__number text-primary"><%= @missions.sum { |m| m.steps.count { |s| s.step_status.title == "Bloquée" } } %></p>
      <p class="stat-card__label">à <strong>traiter</strong></p>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <p class="stat-card__number"><%= @missions.count { |m| m.mission_status.title == "En attente" } %></p>
      <p class="stat-card__label">en attente <strong>client</strong></p>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <p class="stat-card__number"><%= @stats[:clients] %></p>
      <p class="stat-card__label"><strong>clients</strong></p>
    </div>
  </div>
</div>

<%# Missions table %>
<div class="missions-table-card" data-controller="mission-filter">
  <div class="missions-table-card__header">
    <h2 class="missions-table-card__title">Toutes mes missions</h2>
    <div class="missions-table-tabs">
      <button class="missions-table-tabs__tab active"
              data-mission-filter-target="tab"
              data-filter="all"
              data-action="click->mission-filter#filter">
        Toutes
      </button>
      <button class="missions-table-tabs__tab"
              data-mission-filter-target="tab"
              data-filter="en-cours"
              data-action="click->mission-filter#filter">
        En cours
      </button>
      <button class="missions-table-tabs__tab"
              data-mission-filter-target="tab"
              data-filter="terminee"
              data-action="click->mission-filter#filter">
        Terminées
      </button>
    </div>
  </div>

  <table class="missions-table w-100">
    <thead>
      <tr>
        <th>MISSION</th>
        <th>CLIENT</th>
        <th>AVANCEMENT</th>
        <th>STATUT</th>
      </tr>
    </thead>
    <tbody>
      <% @missions.each do |mission| %>
        <% steps_total = mission.steps.size %>
        <% steps_done  = mission.steps.count { |s| s.step_status.title == "Validée" } %>
        <% progress    = steps_total > 0 ? (steps_done.to_f / steps_total * 100).round : 0 %>
        <% status_slug = mission.mission_status.title.parameterize %>
        <tr data-mission-filter-target="row" data-status="<%= status_slug %>">
          <td class="missions-table__mission-cell">
            <p class="missions-table__mission-title"><%= mission.title %></p>
            <p class="missions-table__mission-meta">
              créé le <%= mission.created_at.strftime("%-d %B") %> &middot; <%= steps_total %> étape<%= steps_total > 1 ? "s" : "" %>
            </p>
          </td>
          <td>
            <div class="client-cell">
              <div class="client-avatar">
                <%= "#{mission.client.first_name[0]}#{mission.client.last_name[0]}" %>
              </div>
              <span class="client-cell__name">
                <%= mission.client.last_name[0] %>. <%= mission.client.first_name %>
              </span>
            </div>
          </td>
          <td class="missions-table__progress-cell">
            <div class="progress missions-progress" style="height: 6px;">
              <div class="progress-bar missions-progress__bar missions-progress__bar--<%= progress == 100 ? 'full' : (progress < 35 ? 'low' : 'mid') %>"
                   role="progressbar"
                   style="width: <%= progress %>%">
              </div>
            </div>
            <span class="missions-progress__pct"><%= progress %>%</span>
          </td>
          <td>
            <span class="mission-badge mission-badge--<%= status_slug %>">
              &bull; <%= mission.mission_status.title %>
            </span>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
