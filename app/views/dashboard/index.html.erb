<% profile = current_user.profile %>

<div data-controller="pav-sync">
<div class="dashboard-header">
  <div>
    <h1 class="dashboard-header__title">Tableau de bord</h1>
    <p class="dashboard-header__subtitle">
      Bonjour <%= profile&.first_name || current_user.email.split("@").first %> &mdash;
      <%= @missions.count %> mission<%= @missions.count > 1 ? "s" : "" %> en cours
    </p>
  </div>

  <div class="dashboard-header__actions">
    <% if current_user.gmail_connection.present? %>
      <div data-pav-sync-target="syncBtn">
        <%= button_to sync_all_missions_path,
              method: :post,
              data: { action: "click->pav-sync#syncAll" },
              class: "btn btn-danger vesta-btn text-white rounded-pill" do %>
          <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Analyser les échanges
        <% end %>
      </div>
      <div data-pav-sync-target="syncLoader" class="d-none">
        <div class="spinner-grow spinner-grow-sm text-danger me-1" role="status"></div>
        <span class="small text-muted">IA — <span data-pav-sync-target="syncWord" class="gmail-sync__word fw-semibold text-dark"></span></span>
      </div>
    <% else %>
      <%= button_to user_google_oauth2_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          class: "btn btn-outline-danger vesta-btn rounded-pill" do %>
        <i class="fa-brands fa-google me-1"></i> Connecter Gmail
      <% end %>
    <% end %>

    <div class="dashboard-header__helper">
      <small class="text-muted">Crée une synthèse IA et identifie les nouvelles décisions par mission</small>
      <div class="dropdown">
        <button type="button" class="hiw-trigger" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="fa-solid fa-circle-question"></i>
        </button>
        <div class="dropdown-menu dropdown-menu-end hiw-dropdown p-3">
          <p class="fw-bold mb-2 hiw-dropdown__title">Comment ça marche ?</p>
          <p class="small mb-3 hiw-dropdown__desc">Vesta lit les emails Gmail de chaque mission et génère automatiquement une synthèse et les décisions à prendre.</p>
          <div class="d-flex flex-column gap-2">
            <% [
              "Récupère les derniers échanges avec tes clients",
              "Identifie les décisions validées et en attente",
              "Met à jour la synthèse de chaque mission"
            ].each_with_index do |step, i| %>
              <div class="d-flex align-items-start gap-2">
                <span class="hiw-step-num"><%= i + 1 %></span>
                <span class="small hiw-dropdown__step-text"><%= step %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Stats row %>
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="stat-card">
      <p class="stat-card__number"><%= @stats[:active] %></p>
      <p class="stat-card__label">missions <strong>actives</strong></p>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card stat-card--highlight">
      <p class="stat-card__number text-primary"><%= @missions.sum { |m| m.steps.count { |s| s.step_status.title == "Bloquée" } } %></p>
      <p class="stat-card__label">à <strong>traiter</strong></p>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <p class="stat-card__number"><%= @missions.count { |m| m.mission_status.title == "À démarrer" } %></p>
      <p class="stat-card__label">en attente <strong>client</strong></p>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <p class="stat-card__number"><%= @stats[:clients] %></p>
      <p class="stat-card__label"><strong>clients</strong></p>
    </div>
  </div>
</div>

<%# Points à valider %>
<% if @pending_logs_by_mission.any? %>
  <div id="pav_card" class="pav-card mb-4">
    <div class="pav-card__header">
      <div class="pav-card__title-group">
        <h2 class="pav-card__title"><i class="fa-regular fa-circle-pause text-danger"></i> Points à valider</h2>
      </div>
      <div class="pav-card__actions">
        <p class="pav-card__subtitle mb-0">
          <span id="pav_total_vesta" class="pav-card__subtitle--vesta"><%= @total_vesta_pending %> côté <%= profile&.first_name %> <%= profile&.last_name %></span> &middot;
          <span id="pav_total_client" class="pav-card__subtitle--client"><%= @total_client_pending %> côté client</span>
        </p>
      </div>
    </div>

    <% @pending_logs_by_mission.each do |entry| %>
      <%= turbo_stream_from "gmail_sync_#{entry[:mission].id}" %>
    <% end %>

    <div class="pav-list" data-controller="mission-accordion">
      <% @pending_logs_by_mission.each do |entry| %>
        <% m = entry[:mission] %>
        <% current_step = m.steps.find { |s| s.step_status.title == "En cours" } %>

        <div id="pav_row_<%= m.id %>" class="pav-row" data-mission-accordion-target="row">
          <div class="pav-row__summary"
               data-action="click->mission-accordion#toggle"
               data-mission-accordion-target="summary">
            <div class="pav-row__identity">
              <span class="pav-row__mission-title"><%= m.title %></span>
              <span class="pav-row__meta">
                <%= m.client.first_name %> <%= m.client.last_name %>
                <% if current_step %>&middot; <%= current_step.title %><% end %>
              </span>
            </div>
            <%= render "dashboard/pav_sync_label", mission: m, state: :neutral %>
            <div class="pav-row__badges">
              <span id="pav_vesta_badge_<%= m.id %>" class="pav-badge pav-badge--vesta <%= entry[:vesta_count] > 0 ? '' : 'pav-badge--inactive' %>">
                &bull; <%= entry[:vesta_count] %> <%= profile&.first_name %>
              </span>
              <span id="pav_client_badge_<%= m.id %>" class="pav-badge pav-badge--client <%= entry[:client_count] > 0 ? '' : 'pav-badge--inactive' %>">
                &bull; <%= entry[:client_count] %> client
              </span>
              <span class="pav-chevron" data-mission-accordion-target="chevron">›</span>
            </div>
          </div>

          <div class="pav-row__detail" data-mission-accordion-target="detail">
            <% entry[:logs].each do |log| %>
              <%= render "decision_logs/pav_log_item", log: log, profile: profile %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Missions table %>
<div class="missions-table-card" data-controller="mission-filter">
  <div class="missions-table-card__header">
    <h2 class="missions-table-card__title"><i class="fa-solid fa-bullseye text-info"></i> Toutes mes missions en cours</h2>
    <%= link_to missions_path, class: "ms-2 btn btn-outline-danger vesta-btn rounded-pill" do %>
        <i class="fa-solid fa-eye d-inline-block me-2"></i>
        Voir les missions
    <% end %>
  </div>

  <%= render "shared/missions_table", missions: @missions.select { |m| m.mission_status.title == "En cours" } %>
</div>
</div>
