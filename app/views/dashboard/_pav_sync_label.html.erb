<span id="pav_sync_label_<%= mission.id %>"
      class="pav-sync-label text-secondary"
      data-pav-sync-target="syncLabel"
      data-synced-at="<%= mission.last_synced_at&.iso8601 %>"
      data-state="<%= state %>">
  <% if state == :loading %>
    <i class="ti ti-loader pav-sync-label__spin"></i> synchronisation...
  <% elsif state == :error %>
    <i class="ti ti-alert-circle"></i> erreur synchro
  <% elsif state == :fresh || mission.last_synced_at.present? %>
    <i class="ti ti-circle-check"></i> à l'instant
  <% else %>
    <i class="ti ti-clock"></i> jamais synchronisé
  <% end %>
</span>
