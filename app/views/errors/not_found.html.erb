<% content_for :title, "Page introuvable – Vesta" %>

<div class="error-page">
  <div class="error-card">
    <div class="error-logo">
      <%= image_tag "logo.svg", height: 32, alt: "Vesta" %>
      <span>VESTA</span>
    </div>

    <div class="error-code">404</div>

    <h1 class="error-title">Page introuvable</h1>
    <p class="error-message">
      La page que vous recherchez n'existe pas ou a été déplacée.
    </p>

    <%= link_to root_path, class: "btn btn-danger vesta-btn text-white rounded-pill error-btn" do %>
      Retour à l'accueil
    <% end %>
  </div>
</div>
