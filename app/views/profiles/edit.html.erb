<div class="container-fluid profile-edit p-4">
  <h1 class="profile-edit__title">Mon profil</h1>
  <p class="text-muted mb-4">Renseignez vos informations personnelles et chartez la page de vos projets que vous partagerez à vos clients.</p>

  <%= simple_form_for @profile, url: profile_path, method: :patch, class: "profile-edit-form" do |f| %>
    <div class="row">
      <div class="col-12 col-md-6">
        <div class="bg-white border rounded-4 p-4">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div class="profile-edit__avatar">
              <% if @profile.first_name.present? && @profile.last_name.present? %>
                <%= "#{@profile.first_name}#{@profile.last_name}"[0..1].upcase %>
              <% else %>
                <%= current_user.email[0..1].upcase %>
              <% end %>
            </div>
            <div>
              <p class="fw-semibold mb-0"><%= current_user.email %></p>
              <p class="text-muted small mb-0">Membre depuis <%= l(current_user.created_at, format: "%B %Y") %></p>
            </div>
          </div>

          <div class="form-group mb-3">
            <%= f.input :first_name,
              label: "Prénom",
              required: false,
              input_html: { class: "rounded-4" } %>
          </div>

          <div class="form-group mb-3">
            <%= f.input :last_name,
              label: "Nom",
              required: false,
              input_html: { class: "rounded-4" } %>
          </div>

          <div class="d-flex justify-content-between mt-4">
            <%= link_to root_path, class: "btn btn-outline-danger rounded-pill" do %>
              <i class="fa-solid fa-angle-left"></i> Retour
            <% end %>
            <%= f.submit "Enregistrer", class: "btn btn-danger rounded-pill text-white" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
